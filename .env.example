# PostgreSQL connection string
# Get a free DB from https://neon.tech or https://supabase.com
DATABASE_URL=postgresql://user:password@host:5432/deskguard

# Secret key for JWT signing — use any long random string
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_long_random_string
